   r_w=1.269-0.00037*A+2e-6*A**2-4e-9*A**3                        3231 1451
   r_so=r_u                                                       3231 1451
   a_u=0.66                                                       3231 1451
   a_w=0.48                                                       3231 1451
   a_so=a_u                                                       3231 1451
